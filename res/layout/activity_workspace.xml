<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#252526"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:elevation="4dp">

        <!-- 侧边栏切换按钮 -->
        <ImageView
            android:id="@+id/btn_toggle_sidebar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#CCCCCC"
            android:padding="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="切换侧边栏" />

        <!-- 工作区路径 -->
        <TextView
            android:id="@+id/tv_workspace_path"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/workspace"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:singleLine="true"
            android:ellipsize="middle"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:padding="4dp"
            android:background="#1E1E1E" />

        <!-- 执行按钮 -->
        <ImageView
            android:id="@+id/btn_run"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="#4CAF50"
            android:padding="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="执行" />

        <!-- 菜单按钮 -->
        <ImageView
            android:id="@+id/btn_menu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#CCCCCC"
            android:padding="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="菜单" />
    </LinearLayout>

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 侧边栏 -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#252526"
            android:visibility="visible">

            <!-- 侧边栏标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:background="#2D2D2D">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="资源管理器"
                    android:textSize="12sp"
                    android:textColor="#CCCCCC"
                    android:textStyle="bold" />

                <!-- 新建按钮（文件/文件夹） -->
                <ImageView
                    android:id="@+id/btn_new"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:tint="#CCCCCC"
                    android:padding="4dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="新建" />
            </LinearLayout>

            <!-- 资源管理器路径显示栏 -->
            <TextView
                android:id="@+id/tv_sidebar_path"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:text="/workspace"
                android:textSize="11sp"
                android:textColor="#999999"
                android:singleLine="true"
                android:ellipsize="middle"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:gravity="center_vertical"
                android:background="#252526" />

            <!-- 文件树列表 -->
            <ListView
                android:id="@+id/file_tree"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:divider="#2D2D2D"
                android:dividerHeight="1dp"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- 编辑器区域 -->
        <LinearLayout
            android:id="@+id/editor_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E1E1E">

            <!-- 最近文件顶栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:background="#2D2D2D">

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/recent_files_container"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="最近打开: "
                            android:textSize="11sp"
                            android:textColor="#999999"
                            android:layout_marginRight="8dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 保存按钮 -->
                <ImageView
                    android:id="@+id/btn_save"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:tint="#4CAF50"
                    android:padding="6dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="保存" />
            </LinearLayout>

            <!-- 编辑器内容区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- 撤销/重做按钮栏（动态显示） -->
                <LinearLayout
                    android:id="@+id/undo_redo_bar"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:background="#2D2D2D"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:visibility="gone">

                    <!-- 撤销按钮 -->
                    <ImageView
                        android:id="@+id/btn_undo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="#666666"
                        android:padding="6dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="撤销"
                        android:enabled="false" />

                    <!-- 重做按钮 -->
                    <ImageView
                        android:id="@+id/btn_redo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        android:tint="#666666"
                        android:padding="6dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="重做"
                        android:enabled="false" />
                </LinearLayout>

                <!-- 空状态 -->
                <TextView
                    android:id="@+id/empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择一个文件开始编辑"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:visibility="visible"
                    android:layout_gravity="center"
                    android:layout_marginTop="100dp" />

                <!-- 编辑器内容 -->
                <ScrollView
                    android:id="@+id/editor_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:fillViewport="true">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- 行号显示 -->
                            <TextView
                                android:id="@+id/line_numbers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="50dp"
                                android:background="#1E1E1E"
                                android:textColor="#666666"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:paddingTop="16dp"
                                android:paddingBottom="16dp"
                                android:paddingLeft="16dp"
                                android:paddingRight="8dp"
                                android:gravity="top|end"
                                android:text="1" />

                            <!-- 编辑器内容 -->
                            <EditText
                                android:id="@+id/editor_content"
                                android:layout_width="wrap_content"
                                android:minWidth="300dp"
                                android:layout_height="wrap_content"
                                android:minHeight="400dp"
                                android:background="#1E1E1E"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:padding="16dp"
                                android:gravity="top|start"
                                android:inputType="textMultiLine"
                                android:scrollbars="vertical" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </ScrollView>
            </LinearLayout>

            <!-- 字数统计栏 -->
            <LinearLayout
                android:id="@+id/word_count_bar"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#252526"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_word_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 字符 | 0 行"
                    android:textSize="11sp"
                    android:textColor="#999999" />

                <ImageView
                    android:id="@+id/btn_word_count_details"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:tint="#CCCCCC"
                    android:padding="4dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="字数统计详情" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 终端输出区域 -->
    <LinearLayout
        android:id="@+id/terminal_panel"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:visibility="gone">

        <!-- 终端标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2D2D2D"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="终端输出"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_clear_terminal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#CCCCCC"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="清空终端" />

            <ImageView
                android:id="@+id/btn_hide_terminal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#CCCCCC"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="隐藏终端" />
        </LinearLayout>

        <!-- 终端输出内容 -->
        <ScrollView
            android:id="@+id/terminal_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:padding="8dp"
            android:paddingBottom="280dp"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/terminal_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待执行..."
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:fontFamily="monospace"
                android:gravity="bottom|start" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>