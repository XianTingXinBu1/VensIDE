<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#252526"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:elevation="4dp">

        <!-- 侧边栏切换按钮 -->
        <ImageView
            android:id="@+id/btn_toggle_sidebar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#CCCCCC"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="切换侧边栏" />

        <!-- 工作区路径 -->
        <TextView
            android:id="@+id/tv_workspace_path"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/workspace"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:singleLine="true"
            android:ellipsize="middle"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:padding="4dp"
            android:background="#1E1E1E" />

        <!-- 保存按钮 -->
        <ImageView
            android:id="@+id/btn_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_save"
            android:tint="#CCCCCC"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="保存" />

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#CCCCCC"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />
    </LinearLayout>

    <!-- 最近文件顶栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#2D2D2D"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/recent_files_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最近打开: "
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginRight="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 侧边栏 -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#252526"
            android:visibility="visible">

            <!-- 侧边栏标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:background="#2D2D2D">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="资源管理器"
                    android:textSize="12sp"
                    android:textColor="#CCCCCC"
                    android:textStyle="bold" />

                <!-- 新建按钮（文件/文件夹） -->
                <ImageView
                    android:id="@+id/btn_new"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:tint="#CCCCCC"
                    android:padding="4dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="新建" />
            </LinearLayout>

            <!-- 资源管理器路径显示栏 -->
            <TextView
                android:id="@+id/tv_sidebar_path"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:text="/workspace"
                android:textSize="11sp"
                android:textColor="#999999"
                android:singleLine="true"
                android:ellipsize="middle"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:gravity="center_vertical"
                android:background="#252526" />

            <!-- 文件树列表 -->
            <ListView
                android:id="@+id/file_tree"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:divider="#2D2D2D"
                android:dividerHeight="1dp"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- 编辑器区域 -->
        <LinearLayout
            android:id="@+id/editor_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:gravity="center">

            <!-- 空状态 -->
            <TextView
                android:id="@+id/empty_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择一个文件开始编辑"
                android:textSize="16sp"
                android:textColor="#666666"
                android:visibility="visible" />

            <!-- 编辑器内容 -->
            <ScrollView
                android:id="@+id/editor_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:fillViewport="true">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 行号显示 -->
                        <TextView
                            android:id="@+id/line_numbers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="50dp"
                            android:background="#1E1E1E"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="8dp"
                            android:gravity="top|end"
                            android:text="1" />

                        <!-- 编辑器内容 -->
                        <EditText
                            android:id="@+id/editor_content"
                            android:layout_width="wrap_content"
                            android:minWidth="300dp"
                            android:layout_height="wrap_content"
                            android:minHeight="400dp"
                            android:background="#1E1E1E"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:padding="16dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:scrollbars="vertical" />
                    </LinearLayout>
                </HorizontalScrollView>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>